<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0d1220;--navy2:#1a3fa0;--navy3:#1231780;
  --blue:#1a3fa0;--blue2:#2451c8;--blue3:#e8f0fc;--blue4:#c5d7f7;
  --gold:#c9973a;--gold2:#e8b96a;--gold3:#fff4e0;
  --teal:#2a9d8f;--coral:#e76f51;--sq-blue:#4a90d9;--sq-yellow:#e8b84b;
  --cream:#f2f4f8;--cream2:#e2e8f0;
  --text:#0d1220;--text2:#374151;--text3:#8a9bb0;
  --danger:#c0392b;--danger-bg:#fef0ee;--warning:#c87d1a;--warning-bg:#fef9ee;--success:#1a7f4b;--success-bg:#eef8f3;
  --r:12px;--sh:0 2px 20px rgba(26,63,160,.10)
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;font-size:14px}
@keyframes blink-w{0%,100%{border-color:var(--warning)}50%{border-color:transparent}}
@keyframes blink-r{0%,100%{border-color:var(--danger)}50%{border-color:transparent}}
.bw{animation:blink-w 1s step-end infinite;border:2px solid var(--warning)!important}
.br{animation:blink-r 1s step-end infinite;border:2px solid var(--danger)!important}
#banner{display:none;background:var(--danger);color:#fff;padding:9px 20px;font-size:13px;font-weight:600;text-align:center;cursor:pointer}
#banner b{background:rgba(255,255,255,.2);border-radius:20px;padding:1px 9px;margin:0 3px}
.sb{position:fixed;left:0;top:0;bottom:0;width:250px;background:var(--navy);color:#fff;display:flex;flex-direction:column;z-index:100;transition:transform .3s}
.sb-logo{padding:0;border-bottom:1px solid rgba(255,255,255,.10)}
.sb-logo-img{width:100%;background:var(--navy);padding:20px 22px 16px;display:flex;flex-direction:column;align-items:center}
.sb-logo-img img{width:180px;height:auto;display:block}
.sb-logo p{font-size:10px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1.2px;margin-top:8px;text-align:center}
.sb-nav{flex:1;padding:12px 10px;display:flex;flex-direction:column;gap:2px}
.ni{display:flex;align-items:center;gap:9px;padding:10px 12px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:rgba(255,255,255,.55);transition:all .15s}
.ni:hover{background:rgba(255,255,255,.07);color:#fff}
.ni.on{background:rgba(74,144,217,.22);color:var(--sq-blue);font-weight:600}
.ni svg{width:16px;height:16px;flex-shrink:0}
.nbadge{background:var(--danger);color:#fff;border-radius:20px;font-size:10px;font-weight:700;padding:1px 6px;margin-left:auto;display:none}
.sb-foot{padding:12px 20px;border-top:1px solid rgba(255,255,255,.08);font-size:11px;color:rgba(255,255,255,.22)}
.main{margin-left:250px;min-height:100vh}
.wrap{padding:26px 30px}
.pg{display:none}.pg.on{display:block}
.tbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:10px}
.tbar-t{font-family:'DM Serif Display',serif;font-size:25px;color:var(--blue)}
.tbar-s{font-size:12px;color:var(--text3);margin-top:2px}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:13px;margin-bottom:22px}
.sc{background:#fff;border-radius:var(--r);padding:16px;box-shadow:var(--sh);border:1px solid rgba(13,27,42,.06)}
.sc .lbl{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:7px}
.sc .val{font-size:27px;font-weight:600;color:var(--blue)}
.bdg{display:inline-block;margin-top:5px;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:500}
.bd{background:var(--danger-bg);color:var(--danger)}
.bw2{background:var(--warning-bg);color:var(--warning)}
.bg{background:var(--success-bg);color:var(--success)}
.tw{background:#fff;border-radius:var(--r);box-shadow:var(--sh);overflow:hidden}
.th{display:flex;align-items:center;justify-content:space-between;padding:13px 18px;border-bottom:1px solid var(--cream2);flex-wrap:wrap;gap:9px}
.th h3{font-size:14px;font-weight:600}
.srch{display:flex;align-items:center;gap:7px;background:var(--cream);border-radius:8px;padding:6px 11px}
.srch input{border:none;background:transparent;font-size:13px;outline:none;width:160px;font-family:'DM Sans',sans-serif}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{padding:9px 13px;text-align:left;font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;background:var(--cream);border-bottom:1px solid var(--cream2)}
tbody tr{border-bottom:1px solid var(--cream2);transition:background .1s}
tbody tr:last-child{border:none}
tbody tr:hover{background:var(--blue3)}
tbody td{padding:10px 13px;vertical-align:middle}
tr.rw{background:#fffbf0!important}
tr.rd{background:#fff5f5!important}
.pill{display:inline-block;padding:3px 9px;border-radius:20px;font-size:10px;font-weight:700}
.pa{background:var(--success-bg);color:var(--success)}
.pw{background:var(--warning-bg);color:var(--warning)}
.pv{background:var(--danger-bg);color:var(--danger)}
.ab{background:none;border:1px solid var(--cream2);padding:4px 9px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:500;color:var(--text2);transition:all .15s;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.ab:hover{background:var(--navy);color:#fff;border-color:var(--blue)}
.ab.del:hover{background:var(--danger);border-color:var(--danger);color:#fff}
.ab.wa:hover{background:#25d366;border-color:#25d366;color:#fff}
.ab.gld:hover{background:var(--gold);border-color:var(--gold);color:#fff}
.btn{background:var(--blue);color:#fff;border:none;padding:9px 15px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;font-family:'DM Sans',sans-serif;transition:background .15s}
.btn:hover{background:var(--blue2)}
.btn.gold{background:var(--gold)}.btn.gold:hover{background:var(--gold2);color:var(--navy)}
.btn.sec{background:var(--cream);color:var(--text2);border:none}.btn.sec:hover{background:var(--cream2)}
.btn.grn{background:#25d366}.btn.grn:hover{background:#1fa854}
.mbg{display:none;position:fixed;inset:0;background:rgba(13,18,32,.65);z-index:200;align-items:center;justify-content:center;padding:16px}
.mbg.on{display:flex}
.mdl{background:#fff;border-radius:16px;width:100%;max-width:560px;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(26,63,160,.22)}
.mdl.lg{max-width:680px}
.mdl.sm{max-width:420px}
.mh{display:flex;align-items:center;justify-content:space-between;padding:17px 21px;border-bottom:1px solid var(--cream2);position:sticky;top:0;background:#fff;z-index:1}
.mh h3{font-size:15px;font-weight:600}
.mcl{background:var(--cream);border:none;width:27px;height:27px;border-radius:50%;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;color:var(--text2)}
.mb{padding:20px;display:grid;gap:13px}
.mb .row{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.mf{padding:13px 21px;border-top:1px solid var(--cream2);display:flex;gap:9px;justify-content:flex-end;align-items:center;flex-wrap:wrap}
label{font-size:11px;font-weight:600;color:var(--text2);display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px}
input,select,textarea{width:100%;padding:8px 11px;border:1.5px solid var(--cream2);border-radius:8px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--text);background:#fff;outline:none;transition:border .15s}
input:focus,select:focus,textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--blue3)}
.dz{border:2px dashed var(--cream2);border-radius:9px;padding:16px;text-align:center;cursor:pointer;color:var(--text3);font-size:13px;margin-top:4px;transition:all .2s}
.dz:hover{background:var(--cream);border-color:var(--gold)}
.dz.drag-over{background:var(--blue3);border-color:var(--blue);border-style:solid;color:var(--blue)}
.cc{cursor:pointer;transition:box-shadow .18s,transform .18s}
.cc:hover{box-shadow:0 6px 24px rgba(26,63,160,.14);transform:translateY(-2px)}
.di{display:flex;align-items:center;gap:9px;padding:7px 9px;background:var(--cream);border-radius:7px;margin-top:7px;font-size:12px}
.dic{width:26px;height:26px;border-radius:5px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;flex-shrink:0;text-transform:uppercase}
.din{flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dis{color:var(--text3);font-size:10px}
.ddl{background:none;border:none;cursor:pointer;color:var(--text3);font-size:15px;padding:0 3px;line-height:1}
.ddl:hover{color:var(--danger)}
.al{display:flex;flex-direction:column;gap:9px}
.ai{display:flex;align-items:center;gap:13px;padding:13px 16px;border-radius:var(--r);border-left:4px solid}
.aw{background:var(--warning-bg);border-color:var(--warning)}
.av{background:var(--danger-bg);border-color:var(--danger)}
.ain{flex:1}.ain-n{font-size:14px;font-weight:600}.ain-d{font-size:11px;color:var(--text3);margin-top:2px}
.aid{font-size:13px;font-weight:700;min-width:50px;text-align:right}
.aw .aid{color:var(--warning)}.av .aid{color:var(--danger)}
.cg{display:grid;grid-template-columns:repeat(auto-fill,minmax(285px,1fr));gap:13px}
.cc{background:#fff;border-radius:var(--r);padding:16px;border:1px solid var(--cream2);box-shadow:var(--sh)}
.cav{width:40px;height:40px;border-radius:50%;color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;flex-shrink:0}
.cn{font-size:14px;font-weight:600;margin-bottom:2px}
.cm{font-size:11px;color:var(--text3);margin-top:2px}
.cap{font-size:11px;margin-top:9px;padding-top:9px;border-top:1px solid var(--cream2);color:var(--text2);display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.cbub{background:#e5ddd5;border-radius:9px;padding:12px;font-size:13px;line-height:1.7}
.cmsg{background:#fff;border-radius:7px;padding:9px 13px;max-width:90%;box-shadow:0 1px 2px rgba(0,0,0,.1);white-space:pre-wrap;word-break:break-word}
.ctim{font-size:10px;color:#999;text-align:right;margin-top:3px}
.wa-btn{background:#25d366;color:#fff;border-radius:8px;font-size:13px;font-weight:600;padding:9px 15px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;font-family:'DM Sans',sans-serif;transition:background .15s;cursor:pointer}
.wa-btn:hover{background:#1fa854}
.cs{background:#fff;border-radius:var(--r);padding:20px;box-shadow:var(--sh);margin-bottom:18px}
.cs h4{font-size:14px;font-weight:600;margin-bottom:14px;padding-bottom:9px;border-bottom:2px solid var(--blue3);color:var(--blue)}
.tag-var{display:inline-block;background:var(--cream);border:1px solid var(--cream2);border-radius:5px;padding:2px 7px;font-size:11px;font-family:monospace;cursor:pointer;color:var(--navy);margin:2px}
.tag-var:hover{background:var(--navy);color:#fff}
.toast{position:fixed;bottom:22px;right:22px;z-index:999;background:var(--blue);color:#fff;padding:10px 17px;border-radius:9px;font-size:13px;font-weight:500;box-shadow:0 8px 24px rgba(0,0,0,.2);transform:translateY(80px);opacity:0;transition:all .3s;pointer-events:none}
.toast.on{transform:translateY(0);opacity:1}.toast.grn{background:#1a7f4b}
#mdl-confirm{z-index:300}
.ham{display:none;position:fixed;top:13px;left:13px;z-index:300;background:var(--blue);border:none;border-radius:7px;padding:7px;cursor:pointer}
.ovl{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:99}
.empty{text-align:center;padding:36px 20px;color:var(--text3);font-size:13px}
.fd{display:flex;flex-direction:column;gap:2px}
.fd-lbl{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.5px}
.fd-val{font-size:14px;font-weight:500;color:var(--text)}
.fd-val a{color:var(--blue);text-decoration:none}
.outras-ap{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:var(--cream);margin-bottom:6px;cursor:pointer;transition:background .15s}
.outras-ap:hover{background:var(--cream2)}
.outras-ap-info{flex:1}
.outras-ap-num{font-size:12px;font-family:monospace;font-weight:600;color:var(--blue)}
.outras-ap-det{font-size:11px;color:var(--text3);margin-top:1px}
.aa-item{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:9px;border-left:4px solid}
.aa-vw{background:var(--warning-bg);border-color:var(--warning)}
.aa-vc{background:var(--danger-bg);border-color:var(--danger)}
.aa-info{flex:1}.aa-nome{font-size:13px;font-weight:600}.aa-det{font-size:11px;color:var(--text3);margin-top:2px}
.aa-dias{font-size:12px;font-weight:700;min-width:55px;text-align:right}
.aa-vw .aa-dias{color:var(--warning)}.aa-vc .aa-dias{color:var(--danger)}
@media(max-width:768px){
  .sb{transform:translateX(-100%)}.sb.on{transform:translateX(0)}
  .main{margin-left:0!important}.wrap{padding:13px;padding-top:56px}
  .ham{display:flex}.ovl.on{display:block}
  .mb .row{grid-template-columns:1fr}
  thead th:nth-child(4),thead th:nth-child(5),tbody td:nth-child(4),tbody td:nth-child(5){display:none}
}
</style>
</head>
