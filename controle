// ====================================================
// PERSISTENCIA вЂ” localStorage com fallback sessionStorage
// Funciona em arquivo local (file://) e hospedado (https://)
// ====================================================
function _set(k,v){
  var s=JSON.stringify(v);
  try{localStorage.setItem(k,s);return true;}catch(e){}
  try{sessionStorage.setItem(k,s);return true;}catch(e){}
  return false;
}
function _get(k){
  var v=null;
  try{v=localStorage.getItem(k);}catch(e){}
  if(v===null){try{v=sessionStorage.getItem(k);}catch(e){}}
  return v;
}
