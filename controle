function waUrl(phone,msg){return 'https://api.whatsapp.com/send?phone='+phone.replace(/\D/g,'')+'&text='+encodeURIComponent(msg);}
function waMsgAp(a){
  var cl=getCl(a.cid),d=dias(a.fim),nome=CFG.nome||'Г“rbita Seguros';
  var tpl=d<0?(CFG.msgVencida||''):(CFG.msgVencendo||'');
  if(!tpl){
    if(d<0)return 'OlГЎ, *'+cl.nome+'*! рџ‘‹\n\nSua apГіlice *'+a.num+'* ('+a.tipo+') estГЎ *VENCIDA* desde '+fmtD(a.fim)+'.\n\nContate-nos para renovar.\n\n*'+nome+'* рџ›ЎпёЏ';
    return 'OlГЎ, *'+cl.nome+'*! рџ‘‹\n\nSua apГіlice *'+a.num+'* ('+a.tipo+') vence em *'+d+' dia(s)* вЂ” '+fmtD(a.fim)+'.\n\nPrГЄmio: *R$ '+(a.val||'consultar')+'*\nSeguradora: '+(a.seg||'вЂ”')+'\n\nContate-nos para renovaГ§ГЈo.\n\n*'+nome+'* рџ›ЎпёЏ';
  }
  return tpl
    .split('{nome}').join(cl.nome)
    .split('{apolice}').join(a.num)
    .split('{tipo}').join(a.tipo)
    .split('{dias}').join(String(Math.abs(d)))
    .split('{vencimento}').join(fmtD(a.fim))
    .split('{valor}').join(a.val||'consultar')
    .split('{seguradora}').join(a.seg||'вЂ”')
    .split('{corretora}').join(nome);
}
