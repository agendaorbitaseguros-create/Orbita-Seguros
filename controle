function renderTbDash(){
  var q=(document.getElementById('dash-q').value||'').toLowerCase();
  var rows=AP.filter(function(a){
    var cl=getCl(a.cid);
    var d=dias(a.fim);
    var passaFiltro=true;
    if(_dashFiltro==='ativas')    passaFiltro=(d>=0 && d>CFG.dias);
    if(_dashFiltro==='vencendo')  passaFiltro=(d>=0 && d<=CFG.dias);
    if(_dashFiltro==='vencidas')  passaFiltro=(d<0);
    if(_dashFiltro==='todas')     passaFiltro=true;
    var passaBusca=!q||(cl&&cl.nome.toLowerCase().indexOf(q)>=0)||a.num.toLowerCase().indexOf(q)>=0;
    return passaFiltro && passaBusca;
  }).sort(function(a,b){return dias(a.fim)-dias(b.fim);});
  var titulo=document.getElementById('dash-tb-titulo');
  if(titulo){
    var labels={'ativas':'Ativas','vencendo':'Vencendo em '+CFG.dias+' dias','vencidas':'Vencidas','todas':'Todas','':'Todas as ApГіlices'};
    titulo.textContent=labels[_dashFiltro]||'Todas as ApГіlices';
  }
  document.getElementById('dash-tb').innerHTML=rows.length?rows.map(apRow).join(''):'<tr><td colspan="7"><div class="empty">Nenhuma apГіlice nesta categoria.</div></td></tr>';
}
function renderTbAp(){
