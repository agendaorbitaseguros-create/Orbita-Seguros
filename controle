    '</div>';
  }
  document.getElementById('dash-stats').innerHTML=
    mkCard('todas','','Total Ap&#243;lices',tot,'bg',CL.length+' clientes')+
    mkCard('ativas','','Ativas',atv,'bg','Em vigor')+
    mkCard('vencendo',vw?'bw':'','Vencendo em '+CFG.dias+'d',vw,'bw2','Aten&#231;&#227;o')+
    mkCard('vencidas',vc?'br':'','Vencidas',vc,'bd','Renovar');

  var d2=new Date();  var d2=new Date();
  document.getElementById('dash-date').textContent=d2.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
  var urg=AP.filter(function(a){return dias(a.fim)<=CFG.dias;}).sort(function(a,b){return dias(a.fim)-dias(b.fim);}).slice(0,3);
  var uel=document.getElementById('dash-urg');
