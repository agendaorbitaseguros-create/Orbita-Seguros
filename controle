          (v?(Math.abs(d2)+'d atrГЎs'):(d2+'d'))+
        '</div>'+
        '<button class="ab wa" onclick="waAp('+a.id+')">'+WA_ICON+' WA</button>'+
      '</div>';
    }).join('')+'</div>';
  } else { uel.innerHTML=''; }
  renderTbDash();
}
