  function mkCard(tipo,animCls,lbl,val,bdgCls,bdgTxt){
    var sel=_dashFiltro===tipo;
    var bc=sel?(selColor[tipo]||'var(--navy)'):'transparent';
    var tc=sel?(selColor[tipo]||'var(--navy)'):'var(--text3)';
