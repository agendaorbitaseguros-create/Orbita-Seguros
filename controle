        '<div class="aa-nome">'+(cl?cl.nome:'вЂ”')+' &nbsp;<span style="font-family:monospace;font-size:11px;font-weight:400">'+a.num+'</span></div>'+
        '<div class="aa-det">'+a.tipo+' вЂў Vence '+fmtD(a.fim)+' вЂў R$ '+(a.val||'вЂ”')+' вЂў '+(a.seg||'')+'</div>'+
      '</div>'+
      '<div class="aa-dias">'+diasTxt+'</div>'+
      '<button class="ab wa" onclick="waAp('+a.id+');fMdl(String.fromCharCode(97,108,101,114,116,97,45,97,117,116,111))">WA</button>'+
    '</div>';
  }).join('');

  var vencidas=urgentes.filter(function(a){return dias(a.fim)<0;}).length;
  var sub=urgentes.length+' apГіlice(s) precisam de atenГ§ГЈo';
  if(vencidas) sub+=(' вЂ” '+vencidas+' jГЎ vencida(s)');
  document.getElementById('alerta-auto-sub').textContent=sub;
  document.getElementById('alerta-nao-hoje').checked=false;

  oMdl('alerta-auto');
}

function irParaAlertas(){
  fMdl('alerta-auto');
  // Registra "nГЈo mostrar hoje" se checkbox marcado
  registrarAvisoHoje();
  nav('alertas');
}

function registrarAvisoHoje(){
  var cb=document.getElementById('alerta-nao-hoje');
  if(cb && cb.checked){
    var hoje2=hoje();
    try{ localStorage.setItem('orbita_ultimo_aviso', hoje2); }catch(e){}
    try{ sessionStorage.setItem('orbita_ultimo_aviso', hoje2); }catch(e){}
  }
}

// Registra ao fechar o modal tambГ©m
document.getElementById('mdl-alerta-auto').addEventListener('click', function(e){
  if(e.target===this) registrarAvisoHoje();
});

