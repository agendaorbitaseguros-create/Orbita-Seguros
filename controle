// ====================================================
function dzOver(e, dzId){
  e.preventDefault(); e.stopPropagation();
  document.getElementById(dzId).classList.add('drag-over');
}
function dzLeave(dzId){
  document.getElementById(dzId).classList.remove('drag-over');
}
function dzDrop(e, dzId, ctx){
  e.preventDefault(); e.stopPropagation();
  document.getElementById(dzId).classList.remove('drag-over');
  var files = Array.from(e.dataTransfer.files);
  if(!files.length) return;
  if(ctx==='novo') processFiles(files, 'novo');
  if(ctx==='modal') processFiles(files, 'modal');
}
function processFiles(files, ctx){
  files.forEach(function(f){
    if(f.size > 5*1024*1024){ toast('Arquivo muito grande (mГЎx 5MB): '+f.name); return; }
    var r = new FileReader();
    if(ctx==='novo'){
      r.onload = function(ev){ _tmpD.push({nome:f.name, sz:f.size, b64:ev.target.result}); renderTmpD(); };
    } else {
      var cl = getCl(_docCid);
      if(!cl.docs) cl.docs = [];
      r.onload = function(ev){
        cl.docs.push({nome:f.name, sz:f.size, b64:ev.target.result});
        salvarTudo(); renderMdlDocs(); renderGrCl();
        toast(f.name+' adicionado!', true);
      };
    }
    r.readAsDataURL(f);
  });
}

function handleFilesNovo(e){
  processFiles(Array.from(e.target.files), 'novo');
  e.target.value='';
}
function renderTmpD(){
  document.getElementById('fc-docs-list').innerHTML=_tmpD.map(function(d,i){
    return'<div class="di"><div class="dic">'+extI(d.nome)+'</div><div class="din">'+d.nome+'</div><div class="dis">'+fmtZ(d.sz)+'</div><button class="ddl" onclick="_tmpD.splice('+i+',1);renderTmpD()">Г—</button></div>';
