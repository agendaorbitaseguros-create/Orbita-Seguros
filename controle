// ====================================================
// UTILS
// ====================================================
function hoje(){return new Date().toISOString().split('T')[0];}
function dias(s){return Math.round((new Date(s)-new Date(hoje()))/86400000);}
function fmtD(s){if(!s)return'вЂ”';var p=s.split('-');return p[2]+'/'+p[1]+'/'+p[0];}
function getCl(id){for(var i=0;i<CL.length;i++)if(CL[i].id==id)return CL[i];return null;}
function nxtId(arr){if(!arr.length)return 1;var m=0;for(var i=0;i<arr.length;i++)if(arr[i].id>m)m=arr[i].id;return m+1;}
function avI(n){return n.split(' ').slice(0,2).map(function(p){return p[0];}).join('').toUpperCase();}
function avC(n){var c=['#0d3b6e','#1a5e3a','#5e1a1a','#1a3e5e','#3e1a5e','#5e3e1a','#1a4a3e'],h=0,i;for(i=0;i<n.length;i++)h=n.charCodeAt(i)+((h<<5)-h);return c[Math.abs(h)%c.length];}
function stAp(fim){var d=dias(fim);if(d<0)return{l:'Vencida',c:'pv'};if(d<=CFG.dias)return{l:'Vence em '+d+'d',c:'pw'};return{l:'Ativa',c:'pa'};}
function extI(n){var e=n.split('.').pop().toLowerCase();return{pdf:'PDF',jpg:'IMG',jpeg:'IMG',png:'IMG',doc:'DOC',docx:'DOC',xls:'XLS',xlsx:'XLS'}[e]||e.toUpperCase();}
function fmtZ(b){if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';}
function toast(m,g){var t=document.getElementById('toast');t.textContent=m;t.className='toast on'+(g?' grn':'');clearTimeout(t._t);t._t=setTimeout(function(){t.className='toast';},3000);}
function badge(){
  var n=0;for(var i=0;i<AP.length;i++)if(dias(AP[i].fim)<=CFG.dias)n++;
  var b=document.getElementById('nbadge');b.textContent=n;b.style.display=n?'inline':'none';
